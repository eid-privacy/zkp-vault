{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": [
    "nodejs@22",
    "typescript@5",
    "bun@1",
    "python@3.14",
    "python314Packages.pip"
  ],
  "shell": {
    "init_hook": [
      "npm install",
      ". $VENV_DIR/bin/activate",
      "pip install -r requirements.txt",
      "ln -sf ../../scripts/pre-commit.sh .git/hooks/pre-commit"
    ],
    "scripts": {
      "navigation:dry":    "npx ts-node utils/addNavigation.ts --dry-run",
      "navigation":        "npx ts-node utils/addNavigation.ts",
      "verify":            "bun run verify",
      "collect-resources": "bun run utils/collectResources.ts",
      "summaries":         "bun run utils/summaries.ts",
      "serve":             "mkdocs serve",
      "build":             "mkdocs build --strict"
    }
  }
}
