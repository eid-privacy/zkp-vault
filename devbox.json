{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": [
    "nodejs@22",
    "typescript@5",
    "bun@1"
  ],
  "shell": {
    "init_hook": [
      "npm install"
    ],
    "scripts": {
      "navigation:dry":       "npx ts-node utils/addNavigation.ts --dry-run",
      "navigation":           "npx ts-node utils/addNavigation.ts",
      "verify":               "bun run verify",
      "migrate-resources":    "bun run utils/migrateResources.ts",
      "gen-summaries":        "bun run utils/summaries.ts"
    }
  }
}
